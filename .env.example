# OpenGodOS 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# AI API 配置 (必需)
# 获取密钥: https://platform.ai-service.com/api_keys
# 注意: 此处的密钥仅为示例，请勿使用
AI_API_KEY=sk-example-key-do-not-use-real-key-here

# AI 服务配置
AI_PROVIDER=ai_service                  # ai_service, local
AI_BASE_URL=https://api.ai-service.com/v1 # API基础URL
AI_TIMEOUT=30                           # 请求超时时间(秒)
AI_MAX_RETRIES=3                        # 最大重试次数
AI_CACHE_ENABLED=true                   # 是否启用缓存
AI_CACHE_TTL=3600                       # 缓存有效期(秒)

# 系统配置
SYSTEM_NAME=OpenGodOS                   # 系统名称
SYSTEM_VERSION=0.1.0                    # 系统版本
LOG_LEVEL=INFO                          # 日志级别: DEBUG, INFO, WARNING, ERROR

# 神经元配置
NEURON_UPDATE_INTERVAL=0.1              # 神经元更新间隔(秒)
SIGNAL_TTL=5.0                          # 信号生存时间(秒)
MAX_NEURONS=1000                        # 最大神经元数量
MAX_SIGNALS=10000                       # 最大信号数量

# 内存配置
MEMORY_SHORT_TERM_CAPACITY=100          # 短时记忆容量
MEMORY_LONG_TERM_CAPACITY=1000          # 长时记忆容量
MEMORY_RETENTION_DAYS=30                # 记忆保留天数

# 情绪系统配置
EMOTION_DECAY_RATE=0.05                 # 情绪衰减率
EMOTION_THRESHOLD=0.3                   # 情绪激活阈值
EMOTION_MAX_STRENGTH=1.0                # 情绪最大强度

# 开发配置
DEBUG_MODE=false                        # 调试模式
TEST_MODE=false                         # 测试模式
MOCK_AI_RESPONSES=false                 # 模拟AI响应(开发用)

# Web界面配置
WEB_HOST=127.0.0.1                      # Web服务器主机
WEB_PORT=5000                           # Web服务器端口
WEB_DEBUG=false                         # Web调试模式
WEB_SECRET_KEY=change_this_secret_key   # Web会话密钥

# 数据库配置 (可选)
DATABASE_URL=sqlite:///opengodos.db     # 数据库URL
DATABASE_ECHO=false                     # 是否输出SQL语句

# 监控配置
MONITOR_ENABLED=true                    # 是否启用监控
MONITOR_PORT=9090                       # 监控端口
METRICS_ENABLED=true                    # 是否启用指标收集

# 安全配置
API_RATE_LIMIT=100                      # API速率限制(每分钟)
CORS_ORIGINS=http://localhost:3000      # CORS允许的源
SESSION_TIMEOUT=3600                    # 会话超时时间(秒)

# 注意:
# 1. 实际部署时请修改所有默认值
# 2. API密钥必须保密，不要提交到版本控制
# 3. 生产环境使用更强的密钥和更严格的配置